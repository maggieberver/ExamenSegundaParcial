@page "/"

@rendermode InteractiveServer

<PageTitle>Registro de productos</PageTitle>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<h4>Registro de productos</h4>

@*Errores*@
@if (!string.IsNullOrEmpty(mensajeError)) {
    <div class="alert alert-danger">@mensajeError</div>
}

@*Input Inventario*@
<div class="row">
    <label for="inventario" class="mb-3 col-sm-2 col-form-label">No. de inventario</label>
    <div class="col-sm-3">
        <input type="number" class="form-control" step="1" id="inventario" @bind="inventario" />
    </div>
</div>

@*Input Nombre*@
<div class="row">
    <label for="descripcion" class="mb-3 col-sm-2 col-form-label">Descripción</label>
    <div class="col-sm-3">
        <input type="text" class="form-control" id="descripcion" @bind="descripcion" />
    </div>
</div>

@*Input Departamento*@
<div class="row mb-3 align-items-center">
    <label class="col-sm-2 col-form-label">Departamento</label>
    <div class="col-sm-10">
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="departamentos" id="frutas" value="Frutas" checked="@(departamento == "Frutas")" @onclick="SeleccionarFrutas">
            <label class="form-check-label" for="frutas">Frutas</label>
        </div>
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="departamentos" id="verduras" value="Verduras" checked="@(departamento == "Verduras")" @onclick="SeleccionarVerduras">
            <label class="form-check-label" for="verduras">Verduras</label>
        </div>
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="departamentos" id="lacteos" value="Lácteos" checked="@(departamento == "Lácteos")" @onclick="SeleccionarLacteos">
            <label class="form-check-label" for="lacteos">Lácteos</label>
        </div>
    </div>
</div>

@*Botones*@
<div class="d-flex gap-2 flex-wrap mb-3">
    <button type="button" class="btn btn-success" @onclick="GuardarDatos">Guardar datos</button>
    <button type="button" class="btn btn-success" @onclick="MostrarListaCompleta">Lista completa</button>
    <button type="button" class="btn btn-success" @onclick="MostrarListaFrutas">Lista de frutas</button>
    <button type="button" class="btn btn-success" @onclick="MostrarListaVerduras">Lista de verduras</button>
    <button type="button" class="btn btn-success" @onclick="MostrarListaLacteos">Lista de lácteos</button>
</div>

@*Tabla*@
@if (mostrarLista) {
    <div class="table-responsive">
        <table class="table table-hover mb-0 table-responsive rounded-3 border shadow-sm overflow-hidden">
            <thead class="table-borderless fw-bold">
                <tr>
                    <td class="col-md-3">No. Inventario</td>
                    <td class="col-md-3">Descripción</td>
                    <td class="col-md-3">Departamento</td>
                </tr>
            </thead>
            <tbody class="table table-hover table-striped border">
                @foreach (var p in productosFiltrados) {
                    <tr>
                        <td>@p.IdInventario</td>
                        <td>@p.Descripcion</td>
                        <td>@p.Departamento</td>
                    </tr>
                }
                @if (!productosFiltrados.Any()) {
                    <tr>
                        <td colspan="3" class="text-center text-muted">No hay productos registrados.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <button type="button" class="btn btn-success mt-3" @onclick="CerrarLista">Cerrar lista</button>
}

@code {
    int inventario;
    string descripcion = "";
    string departamento = "Frutas";
    string? mensajeError;
    
    bool mostrarLista = true;

    List<(int IdInventario, string Descripcion, string Departamento)> productos = new();
    List<(int IdInventario, string Descripcion, string Departamento)> productosFiltrados = new();
    string? departamentoFiltro;

    void GuardarDatos() {
        mensajeError = null;

        if (productos.Any(p => p.IdInventario == inventario)) {
            mensajeError = "El número de inventario se encuentra registrado. Debe ser único.";
            return;
        }
        if (string.IsNullOrWhiteSpace(descripcion)) {
            mensajeError = "La descripción del producto es obligatoria.";
            return;
        }

        productos.Add((inventario, descripcion, departamento));

        LimpiarFormulario();
        ActualizarProductosFiltrados();
    }


    void LimpiarFormulario() {
        inventario = 0;
        descripcion = "";
        departamento = "Frutas";
        mensajeError = null;
    }

    void MostrarListaCompleta() {
        mostrarLista = true;
        departamentoFiltro = null;
        ActualizarProductosFiltrados();
    }

    void MostrarListaPorDepartamento(string dep) {
        mostrarLista = true;
        departamentoFiltro = dep;
        ActualizarProductosFiltrados();
    }

    void MostrarListaFrutas() {
        MostrarListaPorDepartamento("Frutas");
    }

    void MostrarListaVerduras() {
        MostrarListaPorDepartamento("Verduras");
    }

    void MostrarListaLacteos() {
        MostrarListaPorDepartamento("Lácteos");
    }

    void CerrarLista() {
        mostrarLista = false;
    }

    void SeleccionarFrutas() {
        departamento = "Frutas";
    }

    void SeleccionarVerduras() {
        departamento = "Verduras";
    }

    void SeleccionarLacteos() {
        departamento = "Lácteos";
    }

    protected override void OnInitialized() {
        ActualizarProductosFiltrados();
    }

    void ActualizarProductosFiltrados() {
        productosFiltrados.Clear();

        if (string.IsNullOrEmpty(departamentoFiltro)) {
            productosFiltrados.AddRange(productos);
            return;
        }

        foreach (var producto in productos) {
            if (producto.Departamento == departamentoFiltro) {
                productosFiltrados.Add(producto);
            }
        }
    }
}
